{
  "name": "call-booking-backend",
  "version": "1.0.0",
  "description": "Call Booking API backend (Express + Zod + TypeScript)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "zod": "^3.23.8",
    "cors": "^2.8.5",
    "uuid": "^9.0.1"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.1.4",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}
